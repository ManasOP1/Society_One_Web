# SocietyOne Admin Console (Next.js)

# ─── Local development ───────────────────────────────────────────────
# Browser calls same-origin /api/v1 — Next.js rewrites proxy to Nest.
NEXT_PUBLIC_API_BASE_URL=/api/v1
API_PROXY_TARGET=http://localhost:4000

# ─── Vercel production (REQUIRED — set in Vercel → Project → Settings → Environment Variables) ───
#
# Fastest (recommended): call Render API directly — skips the Vercel→Render proxy hop.
#   NEXT_PUBLIC_API_BASE_URL = https://admin-society-one.onrender.com/api/v1
#
# Also set on Render API (Environment):
#   CORS_ORIGINS = https://YOUR-ADMIN.vercel.app,https://YOUR-CUSTOM-DOMAIN
#
# Alternative (same-origin proxy — one extra hop, slightly slower):
#   NEXT_PUBLIC_API_BASE_URL = /api/v1
#   API_PROXY_TARGET         = https://admin-society-one.onrender.com
#
# After changing env vars on Vercel: Redeploy the admin project.
#
# Admin does NOT need DATABASE_URL, JWT secrets, or Supabase keys —
# those belong only on the Nest API (Render).
